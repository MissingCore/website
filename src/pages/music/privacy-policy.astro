---
import type { MDXFrontmatter } from "~/content/Schema";
import { Content, frontmatter } from "~/content/music/privacy-policy.mdx";
import Layout from "~/navigation/layouts/Layout.astro";

import A from "~/components/MDX/A.astro";
import BlockQuote from "~/components/MDX/BlockQuote.astro";
import Divider from "~/components/Divider.astro";
import H1 from "~/components/MDX/H1.astro";
import H2 from "~/components/MDX/H2.astro";
import H3 from "~/components/MDX/H3.astro";
import Ul from "~/components/MDX/Ul.astro";
import Strong from "~/components/MDX/Strong.astro";
---

<Layout {...frontmatter as MDXFrontmatter} class="items-start">
  <Content
    components={{
      a: A,
      blockquote: BlockQuote,
      h1: H1,
      h2: H2,
      h3: H3,
      strong: Strong,
      ul: Ul,
    }}
  />
  <Divider />
  <p>
    <span class="font-semibold underline">Note:</span>
    This mirrors the policy found <A
      href="https://github.com/MissingCore/Music/blob/main/PRIVACY_POLICY.md"
      >in the repository</A
    >.
  </p>
</Layout>
