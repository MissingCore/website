---
import { cn } from "~/lib/style";

interface Props {
  href: string;
  class?: string;
}

const { href, class: className } = Astro.props;
---

<a
  href={href}
  class={cn(
    "w-fit rounded-full bg-primary px-4 py-2 text-center font-bold text-onPrimary uppercase hover:bg-primaryDim",
    className,
  )}
>
  <slot />
</a>
