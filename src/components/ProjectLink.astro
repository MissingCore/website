---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

import { Text } from "@/constants/Style";
import H2 from "./MDX/H2.astro";

interface Props {
  href: string;
  name: string;
  description: string;
  logo: ImageMetadata;
  alt: string;
}

const { href, name, description, logo, alt } = Astro.props;
---

<a
  href={href}
  class="flex w-full items-center gap-2 rounded-[20px] bg-surface p-2 hover:opacity-85"
>
  <Image
    src={logo}
    alt={alt}
    width={80}
    height={80}
    class="max-h-20 max-w-20 rounded-xl"
  />
  <div class="flex shrink grow flex-col gap-2">
    <H2 class="text-2xl">{name}</H2>
    <p class={Text.description}>{description}</p>
  </div>
  <Icon size={48} name="cheveron-right" class="shrink-0 text-n-80" />
</a>
