---
import { Text } from "~/constants/Style";
import { cn } from "~/lib/style";

interface Props {
  id?: string;
  class?: string;
}

const { id, class: className } = Astro.props;
---

<h1
  id={id}
  class:list={cn(
    Text.h1,
    "underline decoration-accent decoration-wavy",
    className
  )}><slot /></h1
>
