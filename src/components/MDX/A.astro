---
interface Props {
  href: string;
}

const { href } = Astro.props;

const isExternalLink = href.startsWith("https://");
---

<a
  href={href}
  {...isExternalLink ? { target: "_blank", rel: "noreffer" } : {}}
  class="text-content underline decoration-accent decoration-wavy hover:opacity-85"
  ><slot /></a
>
