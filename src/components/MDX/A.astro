---
import { cn } from "~/lib/style";

interface Props {
  href: string;
  class?: string;
}

const { href, class: className } = Astro.props;

const isExternalLink = href.startsWith("https://");
---

<a
  href={href}
  {...isExternalLink ? { target: "_blank", rel: "noreferrer" } : {}}
  class:list={cn(
    "text-content underline decoration-accent decoration-wavy hover:opacity-85",
    className
  )}><slot /></a
>
