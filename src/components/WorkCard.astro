---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

import type { Release, Work } from "~/data/Works";

import GlowBadge from "./GlowBadge.astro";
import ReleaseLink from "./ReleaseLink.astro";

interface Props extends Work {}

const { key, name, description, tags, distributions, releases, privacyPolicy } =
  Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/projects/**/icon.png",
);
const iconImgPath = `/src/assets/projects/${key}/icon.png`;
if (!images[iconImgPath]) throw new Error(`"${iconImgPath}" does not exist.`);

function formatRelease({ versionCode, distributors }: Release, stable = false) {
  return {
    versionCode: versionCode,
    stable,
    links: distributors.map((distributor) => ({
      distributor,
      link:
        distributor === "github"
          ? `${distributions.github}/releases/${versionCode}`
          : distributions["google-playstore"]!,
    })),
  };
}

const formattedReleases = [formatRelease(releases.stable, true)];
if (releases.preRelease)
  formattedReleases.push(formatRelease(releases.preRelease));
---

<article
  class="flex aspect-video flex-col gap-8 rounded-xl p-4 shadow-glow shadow-n-30"
>
  <header class="flex flex-row items-center gap-4">
    <Image
      src={images[iconImgPath]()}
      alt={`${name} app icon.`}
      class="size-16 rounded-xl shadow-glow shadow-n-15"
    />
    <div class="min-w-0 flex-1 gap-2">
      <h3 class="truncate font-ntype82 text-xl sm:text-2xl">{name}</h3>
      <p class="truncate text-xs text-n-70 uppercase">{tags.join(" • ")}</p>
    </div>
    <GlowBadge text="Live" color="#D71921" indicator class="hidden sm:flex" />
  </header>

  <p class="-mt-4">{description}</p>

  <div class="space-y-4">
    {formattedReleases.map((release) => <ReleaseLink {...release} />)}
  </div>
</article>
