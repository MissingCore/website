---
import { cn } from "~/lib/style";

/*
  Horizontal list container which spans the whole screen width, which reverts
  to a vertical list on mobile.
*/
---

<div
  class={cn(
    "minimal-scrollbar -mx-4 flex flex-col gap-8 overflow-x-auto p-4 sm:flex-row",
    "sm:-mr-16 sm:-ml-43 sm:pr-16 sm:pl-43",
  )}
>
  <slot />
</div>
