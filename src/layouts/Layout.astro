---
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import type { ComponentProps } from "astro/types";

import "@/assets/global.css";
import { cn } from "@/lib/style";
import MetaHead from "@/components/MetaHead.astro";

interface Props extends ComponentProps<typeof MetaHead> {
  /** Style applied to the `<main />`. */
  class?: string;
}

const { class: className, ...rest } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Font cssVariable="--font-inter" preload/>
    <Font cssVariable="--font-playfair-display"preload />
    <MetaHead {...rest} />
    <ClientRouter />
  </head>
  <body class="bg-canvas flex min-h-svh">
    <main
      class:list={cn(
        "mx-auto flex w-full max-w-2xl flex-col gap-6 px-4 py-32",
        className
      )}
    >
      <slot />
    </main>
  </body>
</html>
