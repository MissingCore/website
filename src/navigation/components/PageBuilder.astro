---
import Layout from "../layouts/Layout.astro";

import type { NonMDXRoute } from "../routes";
import { NavigationTree } from "../routes";
import BackgroundScreen from "./BackgroundScreen.astro";

interface Props {
  route: NonMDXRoute;
}

const { route } = Astro.props;
const screenContext = NavigationTree[route];

const Screen = screenContext.screen;
const PrevScreen = screenContext.prev?.screen;
const NextScreen = screenContext.next?.screen;
---

<Layout title={screenContext.name} description={screenContext.description}>
  <Screen />

  {
    PrevScreen && (
      <BackgroundScreen>
        <PrevScreen unfocused />
      </BackgroundScreen>
    )
  }
  {
    NextScreen && (
      <BackgroundScreen right>
        <NextScreen unfocused />
      </BackgroundScreen>
    )
  }
</Layout>
