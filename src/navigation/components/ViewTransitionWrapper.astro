---
import { cn } from "~/lib/style";

interface Props {
  name: string;
  unfocused?: boolean;
}

const { name, unfocused } = Astro.props;
---

<section
  id={name}
  transition:name={name}
  class:list={cn("w-full max-w-3xl", {
    "max-h-[calc(100svh-16rem)] blur-lg": unfocused,
  })}
>
  <slot />
</section>
